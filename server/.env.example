PORT=4000
NODE_ENV=development

# SQLite by default. To use Postgres in production, change the provider
# in prisma/schema.prisma to "postgresql" and put a real connection
# string here instead.
DATABASE_URL="file:./dev.db"

# Must match the origin your frontend actually runs on.
CLIENT_ORIGIN=http://localhost:3000

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Generate with: npm run hash-password -- "your-password-here"
# Never put the plaintext password here — only the bcrypt hash it prints.
ADMIN_PASSWORD_HASH=

COOKIE_NAME=tr_admin_session
